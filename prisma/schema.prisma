generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Verification {
  id              String   @id @default(cuid())
  inputType       String   // "text" | "url" | "claim"
  inputContent    String   // The original text/URL/claim
  extractedText   String?  // Text extracted from URL (if applicable)
  overallScore    Int      // 0-100
  veracityLevel   String   // "verified" | "dubious" | "false"
  
  // 6 dimensions scores (0-100)
  sourceCredibility   Int
  internalCoherence   Int
  externalCorroboration Int
  sensationalism      Int  // Higher = more sensationalist
  factualAccuracy     Int
  biasManipulation    Int  // Higher = more bias detected
  
  // Detailed analysis (JSON strings)
  dimensionDetails    String  // JSON: detailed analysis per dimension
  sourcesFound        String  // JSON: array of sources with metadata
  silencedVoices      String  // JSON: omitted perspectives
  summary             String  // Overall summary
  
  createdAt DateTime @default(now())
}
